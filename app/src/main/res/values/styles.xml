<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark, flat, Pydroid-like. Built on the framework Material dark theme
         so we pull in zero support/AndroidX dependencies. -->
    <style name="HolyTheme" parent="@android:style/Theme.Material">
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:colorPrimary">@color/bg_bar</item>
        <item name="android:colorPrimaryDark">@color/bg_bar</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:textColor">@color/fg</item>
        <item name="android:textColorPrimary">@color/fg</item>
        <item name="android:textColorSecondary">@color/fg_dim</item>
        <item name="android:textColorHint">@color/fg_dim</item>
    </style>
</resources>
